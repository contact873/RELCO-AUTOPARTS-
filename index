<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RELCO International – Military Vehicle Parts & Components</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0a1628;
    --navy2: #0f2040;
    --navy3: #162a50;
    --amber: #e8861a;
    --amber2: #f5a030;
    --red: #c0392b;
    --green: #27ae60;
    --light: #e8edf5;
    --gray: #8a9ab5;
    --card-bg: #111d30;
    --border: rgba(232,134,26,0.2);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { font-family:'Barlow',sans-serif; background:var(--navy); color:var(--light); overflow-x:hidden; }

  /* TOPBAR */
  .topbar { background:#060e1c; padding:8px 40px; display:flex; align-items:center; justify-content:space-between; font-size:13px; color:var(--gray); border-bottom:1px solid rgba(255,255,255,0.05); }
  .topbar a { color:var(--gray); text-decoration:none; margin-left:18px; }
  .topbar a:hover { color:var(--amber); }
  .topbar .social { display:flex; gap:10px; }
  .topbar .social a { width:26px; height:26px; border-radius:4px; background:var(--navy3); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; color:var(--gray); text-decoration:none; }
  .topbar .social a:hover { background:var(--amber); color:#fff; }

  /* NAVBAR */
  .navbar { background:var(--navy); padding:0 40px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; border-bottom:2px solid var(--amber); box-shadow:0 4px 30px rgba(0,0,0,0.5); }
  .logo { display:flex; align-items:center; gap:12px; padding:14px 0; text-decoration:none; cursor:pointer; }
  .logo-mark { width:46px; height:46px; background:var(--amber); clip-path:polygon(50% 0%,100% 100%,0% 100%); position:relative; display:flex; align-items:center; justify-content:center; }
  .logo-inner { width:30px; height:30px; background:var(--navy); clip-path:polygon(50% 15%,85% 85%,15% 85%); position:absolute; }
  .logo-text .brand { font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; color:#fff; letter-spacing:2px; }
  .logo-text .sub { font-size:10px; color:var(--amber); letter-spacing:3px; text-transform:uppercase; font-weight:600; }
  .nav-links { display:flex; gap:0; }
  .nav-links a { padding:22px 16px; color:var(--light); text-decoration:none; font-size:13px; font-weight:600; letter-spacing:1px; text-transform:uppercase; border-bottom:3px solid transparent; transition:all .2s; cursor:pointer; }
  .nav-links a:hover,.nav-links a.active { color:var(--amber); border-bottom-color:var(--amber); }
  .nav-cta { background:var(--amber)!important; color:var(--navy)!important; padding:10px 22px!important; border-radius:4px; border-bottom:none!important; margin-left:12px; }
  .nav-cta:hover { background:var(--amber2)!important; }

  /* HERO */
  .hero { position:relative; height:600px; overflow:hidden; display:flex; align-items:center; }
  .hero-bg { position:absolute; inset:0; background-size:cover; background-position:center; filter:saturate(0.3) brightness(0.55); transition:opacity 1s; }
  .hero-overlay { position:absolute; inset:0; background:linear-gradient(90deg,rgba(10,22,40,0.96) 42%,rgba(10,22,40,0.4) 100%); }
  .hero-geo { position:absolute; right:-80px; top:50%; transform:translateY(-50%); width:520px; height:520px; border-radius:50%; border:80px solid rgba(232,134,26,0.06); animation:pulse 5s ease-in-out infinite; }
  .hero-geo2 { position:absolute; right:60px; top:50%; transform:translateY(-50%); width:340px; height:340px; border-radius:50%; border:40px solid rgba(232,134,26,0.04); animation:pulse 5s 1.5s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{transform:translateY(-50%) scale(1)} 50%{transform:translateY(-50%) scale(1.05)} }
  .hero-content { position:relative; z-index:2; padding:0 80px; max-width:700px; animation:fadeUp .8s ease both; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
  .hero-tag { display:inline-block; background:var(--amber); color:var(--navy); font-size:11px; font-weight:800; letter-spacing:3px; text-transform:uppercase; padding:5px 14px; border-radius:3px; margin-bottom:20px; }
  .hero h1 { font-family:'Barlow Condensed',sans-serif; font-size:clamp(38px,5vw,66px); font-weight:900; line-height:1.0; text-transform:uppercase; color:#fff; margin-bottom:20px; }
  .hero h1 span { color:var(--amber); }
  .hero p { font-size:16px; color:var(--gray); line-height:1.7; margin-bottom:32px; }
  .hero-btns { display:flex; gap:14px; flex-wrap:wrap; }
  .hero-dots { position:absolute; bottom:28px; left:80px; display:flex; gap:8px; z-index:10; }
  .hero-dot { width:8px; height:8px; border-radius:50%; background:rgba(255,255,255,0.3); cursor:pointer; transition:all .3s; }
  .hero-dot.active { background:var(--amber); width:24px; border-radius:4px; }

  /* BUTTONS */
  .btn-primary { background:var(--amber); color:var(--navy); padding:14px 32px; border-radius:4px; font-weight:800; font-size:13px; letter-spacing:1.5px; text-transform:uppercase; text-decoration:none; transition:all .2s; border:2px solid var(--amber); display:inline-block; }
  .btn-primary:hover { background:var(--amber2); transform:translateY(-2px); box-shadow:0 8px 24px rgba(232,134,26,0.35); }
  .btn-outline { background:transparent; color:#fff; padding:14px 32px; border-radius:4px; font-weight:700; font-size:13px; letter-spacing:1.5px; text-transform:uppercase; text-decoration:none; border:2px solid rgba(255,255,255,0.3); transition:all .2s; display:inline-block; }
  .btn-outline:hover { border-color:var(--amber); color:var(--amber); }

  /* STATS BAR */
  .stats-bar { background:var(--amber); padding:16px 80px; display:flex; justify-content:space-around; align-items:center; gap:20px; }
  .stat { text-align:center; }
  .stat-num { font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; color:var(--navy); }
  .stat-lbl { font-size:11px; font-weight:700; color:var(--navy); opacity:0.7; letter-spacing:1px; text-transform:uppercase; }

  /* SECTION HEADINGS */
  .section-head { text-align:center; padding:60px 40px 20px; }
  .section-head .eyebrow { display:inline-flex; align-items:center; gap:10px; font-size:11px; font-weight:800; letter-spacing:3px; color:var(--amber); text-transform:uppercase; margin-bottom:14px; }
  .section-head .eyebrow::before,.section-head .eyebrow::after { content:''; display:block; width:30px; height:2px; background:var(--amber); }
  .section-head h2 { font-family:'Barlow Condensed',sans-serif; font-size:clamp(30px,4vw,48px); font-weight:900; text-transform:uppercase; color:#fff; margin-bottom:14px; }
  .section-head p { color:var(--gray); max-width:580px; margin:0 auto; line-height:1.7; }

  /* ── VEHICLE SHOWCASE SECTION ── */
  .vehicles-section { padding:20px 40px 60px; background:var(--navy); }
  .vehicles-tabs { display:flex; gap:0; max-width:1200px; margin:0 auto 0; border-bottom:2px solid rgba(255,255,255,0.08); }
  .vtab { padding:14px 28px; font-family:'Barlow Condensed',sans-serif; font-size:16px; font-weight:800; text-transform:uppercase; letter-spacing:1px; color:var(--gray); cursor:pointer; border-bottom:3px solid transparent; margin-bottom:-2px; transition:all .2s; }
  .vtab:hover { color:#fff; }
  .vtab.active { color:var(--amber); border-bottom-color:var(--amber); }
  .vehicle-panels { max-width:1200px; margin:0 auto; }
  .vehicle-panel { display:none; }
  .vehicle-panel.active { display:grid; grid-template-columns:1.1fr 1fr; gap:0; min-height:420px; }
  .veh-img-wrap { position:relative; overflow:hidden; }
  .veh-img-wrap img { width:100%; height:100%; object-fit:cover; filter:saturate(0.5) brightness(0.7); transition:transform .6s; display:block; }
  .veh-img-wrap:hover img { transform:scale(1.04); filter:saturate(0.7) brightness(0.8); }
  .veh-img-overlay { position:absolute; inset:0; background:linear-gradient(90deg,transparent 50%,var(--navy) 100%); }
  .veh-badge { position:absolute; top:20px; left:20px; background:var(--amber); color:var(--navy); font-family:'Barlow Condensed',sans-serif; font-size:13px; font-weight:900; letter-spacing:2px; text-transform:uppercase; padding:6px 16px; border-radius:3px; }
  .veh-info { background:var(--navy2); padding:40px 44px; display:flex; flex-direction:column; justify-content:center; }
  .veh-info h3 { font-family:'Barlow Condensed',sans-serif; font-size:36px; font-weight:900; text-transform:uppercase; color:#fff; margin-bottom:6px; line-height:1; }
  .veh-info .veh-subtitle { color:var(--amber); font-size:13px; font-weight:700; letter-spacing:2px; text-transform:uppercase; margin-bottom:18px; }
  .veh-info p { color:var(--gray); line-height:1.75; font-size:14px; margin-bottom:20px; }
  .veh-specs { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:24px; }
  .veh-spec { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07); border-radius:6px; padding:10px 14px; }
  .veh-spec .spec-key { font-size:10px; font-weight:800; color:var(--amber); letter-spacing:2px; text-transform:uppercase; margin-bottom:4px; }
  .veh-spec .spec-val { font-size:14px; font-weight:600; color:#fff; }
  .veh-parts-label { font-size:11px; font-weight:800; color:var(--amber); letter-spacing:2px; text-transform:uppercase; margin-bottom:12px; }
  .veh-parts-chips { display:flex; gap:8px; flex-wrap:wrap; }
  .veh-chip { background:var(--card-bg); border:1px solid var(--border); color:var(--light); font-size:12px; font-weight:600; padding:5px 12px; border-radius:20px; cursor:pointer; transition:all .2s; }
  .veh-chip:hover { background:var(--amber); color:var(--navy); border-color:var(--amber); }

  /* VEHICLE PARTS GRID */
  .veh-parts-section { padding:10px 40px 60px; background:var(--navy2); }
  .parts-grid-4 { display:grid; grid-template-columns:repeat(4,1fr); gap:18px; max-width:1200px; margin:0 auto; }

  /* NAPCO-style 6-card grid */
  .card-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:3px; padding:30px 40px 60px; max-width:1200px; margin:0 auto; }
  .card { position:relative; height:270px; overflow:hidden; cursor:pointer; display:flex; flex-direction:column; justify-content:flex-end; }
  .card-img { position:absolute; inset:0; background-size:cover; background-position:center; filter:saturate(0.25) brightness(0.45); transition:transform .5s ease, filter .4s; }
  .card:hover .card-img { transform:scale(1.07); filter:saturate(0.55) brightness(0.6); }
  .card-overlay { position:absolute; inset:0; background:linear-gradient(0deg,rgba(10,22,40,0.95) 0%,rgba(10,22,40,0.25) 60%,transparent 100%); }
  .card:hover .card-overlay { background:linear-gradient(0deg,rgba(10,22,40,0.98) 0%,rgba(10,22,40,0.5) 70%,rgba(10,22,40,0.1) 100%); }
  .card-body { position:relative; z-index:2; padding:24px 22px 22px; }
  .card-badge { display:inline-block; background:var(--amber); color:var(--navy); font-size:10px; font-weight:800; letter-spacing:2px; text-transform:uppercase; padding:3px 10px; border-radius:2px; margin-bottom:8px; }
  .card-title { font-family:'Barlow Condensed',sans-serif; font-size:26px; font-weight:900; text-transform:uppercase; color:#fff; line-height:1.1; }
  .card-sub { font-size:12px; color:var(--gray); margin-top:4px; font-weight:500; letter-spacing:.5px; }
  .card-arrow { position:absolute; bottom:22px; right:22px; width:32px; height:32px; border-radius:50%; background:var(--amber); display:flex; align-items:center; justify-content:center; z-index:3; opacity:0; transform:scale(0.6); transition:all .3s; }
  .card:hover .card-arrow { opacity:1; transform:scale(1); }

  /* PRODUCT CARD */
  .product-card { background:var(--card-bg); border:1px solid rgba(255,255,255,0.06); border-radius:8px; overflow:hidden; transition:transform .3s, box-shadow .3s; cursor:pointer; }
  .product-card:hover { transform:translateY(-6px); box-shadow:0 16px 40px rgba(0,0,0,0.4), 0 0 0 1px var(--amber); }
  .product-img { height:170px; background:var(--navy3); display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; }
  .product-img img { width:100%; height:100%; object-fit:cover; filter:saturate(0.5) brightness(0.8); transition:transform .4s; }
  .product-card:hover .product-img img { transform:scale(1.05); }
  .product-img .prod-overlay { position:absolute; inset:0; background:linear-gradient(135deg,rgba(10,22,40,0.3),rgba(232,134,26,0.08)); }
  .prod-badge { position:absolute; top:10px; left:10px; background:var(--red); color:#fff; font-size:10px; font-weight:800; letter-spacing:1px; text-transform:uppercase; padding:3px 8px; border-radius:3px; }
  .prod-badge.new { background:var(--amber); color:var(--navy); }
  .prod-badge.hot { background:#8b1a9e; color:#fff; }
  .product-info { padding:16px; }
  .prod-cat { font-size:10px; font-weight:700; color:var(--amber); letter-spacing:2px; text-transform:uppercase; margin-bottom:6px; }
  .prod-name { font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:700; color:#fff; margin-bottom:5px; line-height:1.2; }
  .prod-sku { font-size:11px; color:var(--gray); margin-bottom:10px; }
  .prod-price { font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:800; color:var(--amber); }
  .prod-price .old { font-size:14px; color:var(--gray); text-decoration:line-through; margin-right:6px; font-family:'Barlow',sans-serif; font-weight:400; }
  .prod-footer { display:flex; gap:8px; padding:0 16px 16px; }
  .btn-cart { flex:1; background:var(--amber); color:var(--navy); border:none; padding:10px; border-radius:4px; font-weight:800; font-size:12px; letter-spacing:1px; text-transform:uppercase; cursor:pointer; transition:background .2s; font-family:'Barlow',sans-serif; }
  .btn-cart:hover { background:var(--amber2); }
  .btn-wish { width:38px; height:38px; border-radius:4px; background:var(--navy3); border:1px solid rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; cursor:pointer; transition:all .2s; }
  .btn-wish:hover { border-color:var(--amber); }
  .btn-wish svg { width:16px; height:16px; }

  /* ABOUT STRIP */
  .about-strip { display:grid; grid-template-columns:1fr 1fr; min-height:420px; overflow:hidden; }
  .about-img { position:relative; overflow:hidden; }
  .about-img img { width:100%; height:100%; object-fit:cover; filter:saturate(0.3) brightness(0.55); display:block; }
  .about-img::after { content:''; position:absolute; inset:0; background:linear-gradient(90deg,transparent,var(--navy) 95%); }
  .about-content { background:var(--navy); padding:60px 60px 60px 50px; display:flex; flex-direction:column; justify-content:center; }
  .about-content h2 { font-family:'Barlow Condensed',sans-serif; font-size:42px; font-weight:900; text-transform:uppercase; color:#fff; margin-bottom:20px; line-height:1.05; }
  .about-content h2 span { color:var(--amber); }
  .about-content p { color:var(--gray); line-height:1.8; margin-bottom:16px; }
  .about-features { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin:24px 0; }
  .about-feat { display:flex; align-items:flex-start; gap:12px; }
  .feat-icon { width:36px; height:36px; flex-shrink:0; background:rgba(232,134,26,0.15); border-radius:6px; display:flex; align-items:center; justify-content:center; }
  .feat-icon svg { width:18px; height:18px; color:var(--amber); }
  .feat-text strong { display:block; font-size:13px; font-weight:700; color:#fff; margin-bottom:2px; }
  .feat-text span { font-size:12px; color:var(--gray); }

  /* SERVICES */
  .services-section { padding:60px 40px; }
  .services-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; max-width:1200px; margin:0 auto; }
  .service-card { background:var(--card-bg); border:1px solid var(--border); border-radius:8px; padding:28px 22px; text-align:center; transition:all .3s; cursor:pointer; }
  .service-card:hover { border-color:var(--amber); transform:translateY(-4px); }
  .service-icon { width:56px; height:56px; border-radius:12px; background:rgba(232,134,26,0.12); margin:0 auto 18px; display:flex; align-items:center; justify-content:center; }
  .service-icon svg { width:26px; height:26px; color:var(--amber); }
  .service-card h3 { font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:800; color:#fff; text-transform:uppercase; margin-bottom:10px; }
  .service-card p { font-size:13px; color:var(--gray); line-height:1.7; }

  /* DOCS STRIP */
  .docs-strip { background:var(--navy3); padding:30px 80px; display:flex; align-items:center; gap:40px; flex-wrap:wrap; }
  .doc-item { display:flex; align-items:center; gap:14px; text-decoration:none; }
  .doc-star { color:var(--amber); font-size:20px; }
  .doc-item-label { font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:800; text-transform:uppercase; color:#fff; letter-spacing:1px; }
  .doc-item-action { background:var(--amber); color:var(--navy); font-size:11px; font-weight:800; letter-spacing:2px; text-transform:uppercase; padding:5px 14px; border-radius:3px; }

  /* STOCKS PAGE */
  .stocks-page { display:none; }
  .stocks-page.visible { display:block; }
  .main-page.hidden { display:none; }
  .items-page { display:none; }
  .items-page.visible { display:block; }

  .page-header { background:linear-gradient(135deg,var(--navy2),var(--navy)); padding:50px 80px 40px; border-bottom:2px solid var(--amber); }
  .page-header h1 { font-family:'Barlow Condensed',sans-serif; font-size:48px; font-weight:900; color:#fff; text-transform:uppercase; }
  .page-header p { color:var(--gray); margin-top:8px; }
  .breadcrumb { display:flex; gap:8px; align-items:center; margin-bottom:16px; }
  .breadcrumb a { color:var(--amber); text-decoration:none; font-size:13px; cursor:pointer; }
  .breadcrumb span { color:var(--gray); font-size:13px; }

  /* STOCK TABLE */
  .stocks-content { padding:40px 80px; }
  .stock-controls { display:flex; gap:14px; align-items:center; margin-bottom:28px; flex-wrap:wrap; }
  .stock-search { flex:1; min-width:220px; background:var(--card-bg); border:1px solid rgba(255,255,255,0.1); border-radius:6px; padding:12px 18px; color:#fff; font-size:14px; font-family:'Barlow',sans-serif; outline:none; transition:border .2s; }
  .stock-search:focus { border-color:var(--amber); }
  .stock-select { background:var(--card-bg); border:1px solid rgba(255,255,255,0.1); border-radius:6px; padding:12px 18px; color:#fff; font-size:13px; font-family:'Barlow',sans-serif; outline:none; cursor:pointer; }
  .stock-table { width:100%; border-collapse:collapse; }
  .stock-table th { background:var(--navy3); color:var(--amber); font-size:11px; font-weight:800; letter-spacing:2px; text-transform:uppercase; padding:14px 18px; text-align:left; border-bottom:2px solid var(--border); }
  .stock-table td { padding:13px 18px; border-bottom:1px solid rgba(255,255,255,0.04); font-size:14px; color:var(--light); vertical-align:middle; }
  .stock-table tr:hover td { background:rgba(232,134,26,0.04); }
  .stock-status { display:inline-block; padding:3px 10px; border-radius:20px; font-size:10px; font-weight:800; letter-spacing:1px; text-transform:uppercase; }
  .in-stock { background:rgba(39,174,96,0.15); color:#27ae60; }
  .low-stock { background:rgba(232,134,26,0.15); color:var(--amber); }
  .out-stock { background:rgba(192,57,43,0.15); color:var(--red); }
  .stock-table .sku { font-family:monospace; font-size:12px; color:var(--gray); }
  .stock-price { font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:700; color:var(--amber); }

  /* ITEMS PAGE */
  .items-grid { display:grid; grid-template-columns:240px 1fr; gap:30px; padding:40px 80px; }
  .filter-panel { background:var(--card-bg); border-radius:8px; border:1px solid rgba(255,255,255,0.06); padding:24px; height:fit-content; }
  .filter-title { font-family:'Barlow Condensed',sans-serif; font-size:18px; font-weight:800; color:#fff; margin-bottom:20px; text-transform:uppercase; }
  .filter-group { margin-bottom:24px; }
  .filter-group-title { font-size:11px; font-weight:800; color:var(--amber); letter-spacing:2px; text-transform:uppercase; margin-bottom:12px; }
  .filter-check { display:flex; align-items:center; gap:10px; margin-bottom:8px; cursor:pointer; }
  .filter-check input { accent-color:var(--amber); width:15px; height:15px; }
  .filter-check label { font-size:13px; color:var(--light); cursor:pointer; }
  .filter-range { width:100%; accent-color:var(--amber); }
  .items-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
  .items-count { color:var(--gray); font-size:13px; }
  .items-sort { background:var(--card-bg); border:1px solid rgba(255,255,255,0.1); border-radius:6px; padding:10px 16px; color:#fff; font-size:13px; font-family:'Barlow',sans-serif; outline:none; }
  .items-list { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; }

  /* CATEGORY PILLS */
  .cat-section { padding:40px 40px 30px; background:var(--navy2); }
  .cat-grid { display:flex; gap:12px; max-width:1200px; margin:0 auto; overflow-x:auto; padding-bottom:8px; }
  .cat-pill { flex-shrink:0; background:var(--card-bg); border:1px solid var(--border); border-radius:40px; padding:10px 22px; display:flex; align-items:center; gap:8px; cursor:pointer; transition:all .2s; text-decoration:none; }
  .cat-pill:hover,.cat-pill.active { background:var(--amber); border-color:var(--amber); }
