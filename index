<script>
// ── PAGE ROUTING ──
const pages = { main:'mainPage', vehicles:'vehiclesPage', stocks:'stocksPage', items:'itemsPage' };
function showPage(page, navEl) {
  Object.values(pages).forEach(id => {
    const el = document.getElementById(id);
    if(el) { el.style.display='none'; el.classList.remove('visible'); }
  });
  const target = page==='home' ? 'main' : page;
  const el = document.getElementById(pages[target]);
  if(el) { el.style.display='block'; el.classList.add('visible'); }
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  if(navEl) navEl.classList.add('active');
  window.scrollTo({top:0, behavior:'smooth'});
}
// init
document.getElementById('mainPage').style.display='block';

// ── HERO SLIDER ──
const slides = [
  { img:'https://upload.wikimedia.org/wikipedia/commons/thumb/e/e6/M812_bridge_truck.jpg/1280px-M812_bridge_truck.jpg', tag:'M-812 · 5-Ton 6×6 Tactical Truck', title:'Parts for <span style="color:var(--amber)">M-812</span><br>& M809 Series', desc:'Cummins NHC-250 engine kits, Dana-Spicer transmissions, winch assemblies and all consumables for the legendary 5-ton 6×6.' },
  { img:'https://upload.wikimedia.org/wikipedia/commons/thumb/0/00/M113A2_Camp_Shelby.jpg/1280px-M113A2_Camp_Shelby.jpg', tag:'APC M113A2 · Armoured Personnel Carrier', title:'Sustaining the <span style="color:var(--amber)">M113A2</span><br>Fleet', desc:'Detroit Diesel 6V53T parts, Allison TX-100 gearbox components, track shoes, road wheels and full rebuild kits.' },
  { img:'https://upload.wikimedia.org/wikipedia/commons/thumb/6/6b/Tatra_813_8x8.jpg/1280px-Tatra_813_8x8.jpg', tag:'Tatra T-813 · 8×8 Heavy Off-Road Truck', title:'<span style="color:var(--amber)">Tatra T-813</span><br>Kolos Parts', desc:'T-930 V12 air-cooled engine components, backbone chassis seals, swing halfshafts, differentials and PTO assemblies.' },
  { img:'https://upload.wikimedia.org/wikipedia/commons/thumb/4/4f/Praga_V3S_military.jpg/1280px-Praga_V3S_military.jpg', tag:'Praga V3S · 6×6 Tactical Truck', title:'<span style="color:var(--amber)">Praga V3S</span><br>Parts & Rebuild Kits', desc:'Praga RN engine spares, fuel injection pumps, steering boxes, axle differentials and complete overhaul kits.' }
];
let currentSlide = 0, slideTimer;
function setSlide(i) {
  currentSlide = i;
  const s = slides[i];
  const bg = document.getElementById('heroBg');
  bg.style.opacity='0';
  setTimeout(()=>{ bg.style.backgroundImage=`url('${s.img}')`; bg.style.opacity='1'; },300);
  document.getElementById('heroTag').textContent='⚙ '+s.tag;
  document.getElementById('heroTitle').innerHTML=s.title;
  document.getElementById('heroDesc').textContent=s.desc;
  document.querySelectorAll('.hero-dot').forEach((d,j)=>d.classList.toggle('active',j===i));
  clearInterval(slideTimer);
  slideTimer = setInterval(nextSlide, 5000);
}
function nextSlide() { setSlide((currentSlide+1)%slides.length); }
slideTimer = setInterval(nextSlide, 5000);

// ── VEHICLE TABS ──
function switchVehicle(id, tab) {
  document.querySelectorAll('.vtab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.vehicle-panel').forEach(p=>p.classList.remove('active'));
  tab.classList.add('active');
  const panel = document.getElementById('panel-'+id);
  if(panel) panel.classList.add('active');
}

// ── CART ──
document.addEventListener('click', function(e) {
  if(e.target.classList.contains('btn-cart')) {
    const orig = e.target.textContent;
    e.target.textContent = '✓ Added!';
    e.target.style.background = '#27ae60';
    setTimeout(()=>{ e.target.textContent=orig; e.target.style.background=''; }, 1400);
  }
  if(e.target.classList.contains('btn-wish')) {
    const svg = e.target.querySelector('path');
    if(svg) { const filled = svg.style.fill==='rgb(232, 134, 26)'; svg.style.fill=filled?'none':'rgb(232,134,26)'; e.target.style.borderColor=filled?'':'var(--amber)'; }
  }
});
</script>
</body>
